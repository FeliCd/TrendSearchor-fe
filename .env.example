# =============================================================
# TrendScholar – Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================

# ---- API -------------------------------------------------------
# Base URL of the backend REST API (no trailing slash)
# Development:  http://localhost:8080
# Production:   https://trendsearchor-be-production.up.railway.app
VITE_API_BASE_URL=http://localhost:8080

# ---- App -------------------------------------------------------
# Public app name displayed in the UI
VITE_APP_NAME=TrendScholar

# App environment: development | staging | production
VITE_APP_ENV=development

# ---- Auth ------------------------------------------------------
# JWT access token TTL in seconds (should match backend config)
# Default: 900 (15 minutes)
VITE_TOKEN_TTL=900

# ---- External API Data Sources ---------------------------------
# These are display-only / informational; actual keys are on the backend.
# Semantic Scholar public API base (no key needed for basic usage)
VITE_SEMANTIC_SCHOLAR_URL=https://api.semanticscholar.org/graph/v1

# OpenAlex public API base
VITE_OPENALEX_URL=https://api.openalex.org

# Crossref public API base
VITE_CROSSREF_URL=https://api.crossref.org

# ---- Feature Flags (optional) ---------------------------------
# Enable/disable features before they are fully released
VITE_FEATURE_REPORT_EXPORT=false
VITE_FEATURE_ADVANCED_TRENDS=false
